# =============================================================================
# 🔐 密钥配置模板（提交到 git）
# =============================================================================
# 复制本文件为 .env，填入真实密钥。
# .env 已在 .gitignore 中排除，不会泄露。
#
# 运行时，ConfigLoader 优先读取环境变量，若未设置则尝试 .env 文件。
# 所有需要密钥的代码应通过 get_secret() 获取，而非直接读 config.yaml。
# =============================================================================

# --- LLM ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
SENSENOVA_API_KEY=sk-your-sensenova-api-key

# --- 数据源 ---
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
# TWITTER_BEARER_TOKEN=your_token_here
# XIAOHONGSHU_COOKIE=your_cookie_here
# XIAOHONGSHU_TOKEN=your_token_here

# --- 认证（JWT 签名用，生产环境务必改掉）---
JWT_SECRET=change-me-to-a-random-string

# --- 图片生成 ---
# BAIDU_IMAGE_API_KEY=...
# BAIDU_IMAGE_SECRET_KEY=...
# VIDU_API_KEY=...
